# Variables d'environnement — Quintessence Spas
# Copier en .env.local (dev) ou les définir dans Vercel (Production).
# En local, sans ces variables, le site utilise les fichiers /data.

# --- Back-office ---
# Mot de passe d'accès à l'admin (changer impérativement en production).
ADMIN_PASSWORD=

# --- Base de données (Vercel KV / Upstash Redis) ---
# Fournies automatiquement par l'intégration Vercel KV (Marketplace > Upstash).
# Dès qu'elles sont présentes, le site lit/écrit en base au lieu des fichiers.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Envoi d'e-mails (Gmail / Google Workspace) — à brancher ensuite ---
# Compte Google Workspace contact@quintessencespas.com + mot de passe
# d'application (Google > Sécurité > Mots de passe d'application).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=contact@quintessencespas.com
SMTP_PASSWORD=
# Adresse d'expédition / réception des notifications internes.
CONTACT_EMAIL=contact@quintessencespas.com
